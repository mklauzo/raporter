# Anthropic API (opcjonalne - mozna tez skonfigurowac w Ustawieniach aplikacji)
ANTHROPIC_API_KEY=sk-ant-...
# Gemini API - konfiguruj w Ustawieniach aplikacji (zakładka Klucze API)

# Flask configuration
SECRET_KEY=change-this-to-a-random-string
FLASK_ENV=production
FLASK_DEBUG=0

# Database configuration
DATABASE_URL=mysql+pymysql://raporter:password@db/raporter

# MySQL/MariaDB
MYSQL_ROOT_PASSWORD=rootpass
MYSQL_DATABASE=raporter
MYSQL_USER=raporter
MYSQL_PASSWORD=password
